# Plantilla de variables de entorno. Copia a `.env` y rellena los valores.
# NUNCA commitees `.env` (está en .gitignore). Cada ejecución del agente gasta API de pago.

# --- Anthropic (obligatorio) ---
# Única key de pago del proyecto. El agente (Sonnet 4.6) y el clasificador de
# guardrails (Haiku 4.5) la usan; web_search, web_fetch y code execution corren
# server-side dentro de la llamada a Anthropic, sin keys adicionales.
ANTHROPIC_API_KEY=

# --- Langfuse (observabilidad) ---
# Nota de región: BASE_URL debe coincidir con la región del proyecto Langfuse.
#   EU -> https://cloud.langfuse.com
#   US -> https://us.cloud.langfuse.com
# Self-hosted: pon aquí tu propia URL.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Guardrails del loop (topes por ejecución) ---
# Tope duro de turnos por ejecución (ver ADR-007).
AGENT_MAX_TURNS=20
# Presupuesto máximo en USD por ejecución; corta el loop si se excede (ver ADR-007).
AGENT_BUDGET_USD=0.80
# Timeout del cliente Anthropic por petición, en segundos.
# 30 s es insuficiente para web_search/web_fetch en ejecuciones reales.
# El CI de evals usa 300 s; para desarrollo local se recomienda ≥ 180 s.
AGENT_TIMEOUT_S=180
# Reintentos de infraestructura por petición (APITimeoutError/APIConnectionError).
# El SDK default es 2; el CI de evals usa 1 para reducir el tiempo de espera máximo.
# Para alinear con CI usa 1; para mayor tolerancia a timeouts transitorios usa 2.
AGENT_MAX_RETRIES=2
# Rate limiting por usuario/IP en el endpoint /research.
RATE_LIMIT_PER_MINUTE=10
